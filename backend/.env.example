# Puerto del servidor
PORT=3000

# API gratuita de Google Gemini (recomendado para informes de reuniones)
# Obtén tu clave en: https://aistudio.google.com/apikey
# Si no la configuras, los informes se generan con análisis por reglas (menos preciso)
GEMINI_API_KEY=

# Opcional: Usar GPU para Whisper si está disponible (cuda)
# Para CPU: "cpu" (por defecto)
WHISPER_DEVICE=cpu
