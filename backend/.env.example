# Configuración para versión GRATUITA
# No necesitas API key de OpenAI!

# Puerto del servidor
PORT=3000

# Opcional: API Key de Hugging Face (mejora límites de uso)
# Obtén una en: https://huggingface.co/settings/tokens
# Si no la configuras, funcionará igual pero con límites más estrictos
HUGGING_FACE_API_KEY=

# Opcional: Modelo de Hugging Face a usar para feedback
# Opciones recomendadas:
# - microsoft/Phi-3-mini-4k-instruct (rápido, pequeño)
# - mistralai/Mistral-7B-Instruct-v0.2 (más potente)
# - meta-llama/Llama-3-8B-Instruct (muy potente, puede tardar más)
HF_MODEL=microsoft/Phi-3-mini-4k-instruct

# Opcional: Usar GPU si está disponible (cuda)
# Para CPU: "cpu" (por defecto)
WHISPER_DEVICE=cpu
