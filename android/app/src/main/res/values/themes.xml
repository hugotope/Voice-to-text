<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base theme used only for the window background and splash before Compose loads.
        All app theming is handled by MeetingFeedbackTheme (Material3 Compose).
    -->
    <style name="Theme.MeetingFeedback" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryVariant">@color/md_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorSecondaryVariant">@color/md_secondary_variant</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/md_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/md_background</item>
        <item name="android:windowBackground">@color/md_background</item>
    </style>
</resources>
